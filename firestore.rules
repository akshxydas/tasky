rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      // DEVELOPMENT ONLY: Allows any user to read and write.
      // This matches the current setup where login is just selecting a predefined name 
      // without actual Firebase Authentication.
      allow read, write: if true;
      
      // For PRODUCTION: when real Firebase Authentication is implemented,
      // replace the above rule with the one below to restrict access to authenticated users:
      // allow read, write: if request.auth != null;
    }
  }
}
